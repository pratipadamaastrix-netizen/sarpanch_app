# Copy to ".env" in this folder (sarpanch_app). Restart runserver after changes.
#
# Leave EMAIL_HOST_USER / EMAIL_HOST_PASSWORD empty → dev mode writes mail to email_outbox/
# Fill both USER and PASSWORD below → Django sends real email (Gmail needs App Password).

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

